# Local Postgres: use the same value for both (Prisma uses DIRECT_URL for migrations).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shiftsync"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/shiftsync"

# Neon / Vercel: DATABASE_URL = pooled connection; DIRECT_URL = direct (non-pooler) — both in Neon dashboard.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-16-chars"
